<?xml version="1.0" encoding="utf-8"?>

<!--
    Fundo padrão para cards, blocos e itens de lista.
    Visual mais refinado e alinhado com a identidade nova do app.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fundo do card -->
    <solid android:color="@color/cor_superficie" />

    <!-- Cantos mais arredondados -->
    <corners android:radius="16dp" />

    <!-- Borda mais suave e alinhada ao tema -->
    <stroke
        android:width="1dp"
        android:color="@color/cor_card_borda" />

</shape>