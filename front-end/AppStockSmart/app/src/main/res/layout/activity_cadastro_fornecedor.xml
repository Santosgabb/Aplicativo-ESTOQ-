<?xml version="1.0" encoding="utf-8"?>

<!--
    Tela de cadastro de fornecedor.
    Estrutura:
    - ScrollView para permitir rolagem em telas menores
    - Cabeçalho com título e subtítulo
    - Card com os campos do formulário
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tela">

    <!-- Container principal da tela -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabeçalho da tela -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/cor_superficie"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cadastrar Fornecedor"
                android:textColor="@color/cor_texto_principal"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Preencha os dados para cadastrar um novo fornecedor"
                android:textColor="@color/cor_texto_secundario"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Card com formulário -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="@color/cor_borda"
            app:strokeWidth="1dp">

            <!-- Conteúdo interno do formulário -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Campo: Nome do fornecedor -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do fornecedor"
                    android:textColor="@color/cor_texto_principal"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtNomeFornecedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite o nome do fornecedor"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="@color/cor_texto_principal"
                    android:textColorHint="@color/cor_texto_secundario" />

                <!-- Campo: Telefone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Telefone"
                    android:textColor="@color/cor_texto_principal"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtTelefoneFornecedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite o telefone"
                    android:inputType="phone"
                    android:padding="12dp"
                    android:textColor="@color/cor_texto_principal"
                    android:textColorHint="@color/cor_texto_secundario" />

                <!-- Campo: Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Email"
                    android:textColor="@color/cor_texto_principal"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtEmailFornecedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite o email"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="@color/cor_texto_principal"
                    android:textColorHint="@color/cor_texto_secundario" />

                <!-- Botão para salvar -->
                <Button
                    android:id="@+id/btnSalvarFornecedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_botao_primario"
                    android:minHeight="52dp"
                    android:text="Salvar Fornecedor"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_claro"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>