<?xml version="1.0" encoding="utf-8"?>

<!--
    Item da lista de usuários.

    Ajustes aplicados:
    - substituído fundo genérico por MaterialCardView
    - borda no padrão novo
    - textos com a nova paleta
    - IDs mantidos para não quebrar o adapter
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/cor_borda">

    <!-- Conteúdo interno do item -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Nome do usuário -->
        <TextView
            android:id="@+id/txtItemNomeUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome do usuário"
            android:textColor="@color/cor_texto_principal"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Login -->
        <TextView
            android:id="@+id/txtItemLoginUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Login: usuario"
            android:textColor="@color/cor_texto_principal"
            android:textSize="14sp" />

        <!-- Perfil -->
        <TextView
            android:id="@+id/txtItemPerfilUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Perfil: CAIXA"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="14sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>