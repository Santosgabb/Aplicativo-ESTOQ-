<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar Produto"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/edtEditarNomeProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do produto"
            android:inputType="text" />

        <Spinner
            android:id="@+id/spinnerEditarTipoProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtEditarPrecoCustoProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Preço de custo"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/spinnerEditarFornecedorProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtEditarPrecoVendaProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Preço de venda"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtEditarQuantidadeProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quantidade"
            android:inputType="number"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnSalvarEdicaoProduto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar Alterações"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>