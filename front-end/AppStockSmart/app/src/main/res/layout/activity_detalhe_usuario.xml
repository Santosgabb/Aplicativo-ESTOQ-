<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalhes do Usuário"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtDetalheNomeUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome:" />

        <TextView
            android:id="@+id/txtDetalheLoginUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Login:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtDetalhePerfilUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Perfil:"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnEditarDetalheUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar Usuário"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnExcluirDetalheUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Excluir Usuário"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>