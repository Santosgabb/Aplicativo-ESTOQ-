<?xml version="1.0" encoding="utf-8"?>

<!--
    Tela de detalhes do usuário.
    Exibe nome, login e perfil.
    Permite:
    - editar
    - inativar
    - reativar
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tela">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabeçalho -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/cor_superficie"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalhes do Usuário"
                android:textColor="@color/cor_texto_principal"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Visualize as informações completas do usuário"
                android:textColor="@color/cor_texto_secundario"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Card principal -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="@color/cor_borda"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nome -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do usuário"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtDetalheNomeUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Nome:"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Login -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Login"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtDetalheLoginUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Login:"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="16sp" />

                <!-- Perfil -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Perfil"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtDetalhePerfilUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Perfil:"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="16sp" />

                <!-- Botão editar -->
                <Button
                    android:id="@+id/btnEditarDetalheUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_botao_primario"
                    android:minHeight="52dp"
                    android:text="Editar Usuário"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_claro"
                    android:textStyle="bold" />

                <!-- Botão inativar -->
                <Button
                    android:id="@+id/btnExcluirDetalheUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_botao_perigo"
                    android:minHeight="52dp"
                    android:text="Inativar Usuário"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_claro"
                    android:textStyle="bold" />

                <!-- Botão reativar -->
                <Button
                    android:id="@+id/btnReativarDetalheUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_botao_primario"
                    android:minHeight="52dp"
                    android:text="Reativar Usuário"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_claro"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>