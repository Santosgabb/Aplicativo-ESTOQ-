<?xml version="1.0" encoding="utf-8"?>

<!--
    Item da lista de produtos.

    Ajustes aplicados:
    - card com borda da nova paleta
    - textos com as cores do tema
    - status mantido em destaque
    - estrutura original preservada
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/cor_borda">

    <!-- Conteúdo interno do card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!--
            Linha superior:
            nome do produto à esquerda
            status do produto à direita
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Nome do produto -->
            <TextView
                android:id="@+id/txtItemNomeProduto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nome do Produto"
                android:textColor="@color/cor_texto_principal"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!--
                Status do produto.
                A Activity/Adapter pode trocar texto e cor dinamicamente.
            -->
            <TextView
                android:id="@+id/txtItemStatusProduto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="ATIVO"
                android:textColor="@color/cor_sucesso"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tipo do produto -->
        <TextView
            android:id="@+id/txtItemTipoProduto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tipo: BEBIDA"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="14sp" />

        <!--
            Linha inferior:
            à esquerda o preço de venda
            à direita a quantidade em estoque
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Bloco do preço -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preço de venda"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtItemPrecoVendaProduto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="R$ 10,00"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bloco do estoque -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estoque"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtItemQuantidadeProduto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="12 un"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>