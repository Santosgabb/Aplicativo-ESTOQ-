<?xml version="1.0" encoding="utf-8"?>

<!--
    Item da lista de fornecedores.

    Ajustes aplicados:
    - borda do card no padrão novo
    - textos usando a nova paleta
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/cor_borda">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtItemNomeFornecedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fornecedor"
            android:textColor="@color/cor_texto_principal"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtItemTelefoneFornecedor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Telefone"
            android:textColor="@color/cor_texto_principal"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtItemEmailFornecedor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Email"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="14sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>