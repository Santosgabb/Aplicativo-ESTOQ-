<?xml version="1.0" encoding="utf-8"?>

<!--
    Tela de menu principal.

    Mantido exatamente no formato original do seu projeto:
    - ScrollView
    - cabeçalho simples
    - lista vertical de cards
    - mesmos IDs dos botões

    Melhorias aplicadas:
    - paleta nova
    - cards mais elegantes
    - textos mais consistentes
    - espaçamentos melhores
    - visual mais profissional sem mudar a estrutura
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tela">

    <!--
        Layout principal da tela.
        Continua no mesmo padrão do seu menu original.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- =========================================================
             CABEÇALHO DA TELA
             ========================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="30dp"
            android:paddingBottom="22dp"
            android:background="@color/cor_superficie">

            <!-- Nome do usuário logado -->
            <TextView
                android:id="@+id/txtNomeUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olá, usuário"
                android:textColor="@color/cor_texto_principal"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- Perfil do usuário logado -->
            <TextView
                android:id="@+id/txtPerfilUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Perfil: GERENTE"
                android:textColor="@color/cor_texto_secundario"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- =========================================================
             ÁREA DOS BOTÕES DO MENU
             ========================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD: VENDAS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnVendas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Vendas"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: PRODUTOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnProdutos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Produtos"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: FORNECEDORES / ESTOQUE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnFornecedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Fornecedores / Estoque"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: USUÁRIOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnUsuarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Usuários"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: RELATÓRIOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnRelatorios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Relatórios"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: FECHAMENTO DE CAIXA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnFechamentoCaixa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Fechamento de Caixa"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: HISTÓRICO DE FECHAMENTOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cor_superficie"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/cor_borda"
                app:strokeWidth="1dp">

                <Button
                    android:id="@+id/btnHistoricoFechamento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:minHeight="78dp"
                    android:paddingHorizontal="22dp"
                    android:text="Histórico de Fechamentos"
                    android:textAllCaps="false"
                    android:textColor="@color/cor_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>