<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Nome do usuário -->
        <TextView
            android:id="@+id/txtNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, usuário"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Perfil do usuário -->
        <TextView
            android:id="@+id/txtPerfilUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil: GERENTE"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtNomeUsuario"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Botão Vendas -->
        <Button
            android:id="@+id/btnVendas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Vendas"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/txtPerfilUsuario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão Produtos -->
        <Button
            android:id="@+id/btnProdutos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Produtos"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnVendas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão Fornecedores / Estoque -->
        <Button
            android:id="@+id/btnFornecedor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Fornecedores / Estoque"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnProdutos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão Usuários -->
        <Button
            android:id="@+id/btnUsuarios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Usuários"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnFornecedor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão Relatórios -->
        <Button
            android:id="@+id/btnRelatorios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Relatórios"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnUsuarios"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>