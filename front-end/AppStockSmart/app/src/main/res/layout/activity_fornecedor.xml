<?xml version="1.0" encoding="utf-8"?>

<!--
    Tela principal de fornecedores.
    Funções:
    - acessar cadastro de fornecedor
    - acessar entrada de estoque
    - listar fornecedores no RecyclerView
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tela"
    android:orientation="vertical">

    <!-- Cabeçalho -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/cor_superficie"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fornecedores"
            android:textColor="@color/cor_texto_principal"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Gerencie fornecedores e entrada de estoque"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Card com ações principais -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/cor_borda"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Título da seção -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ações"
                android:textColor="@color/cor_texto_principal"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Botão: cadastrar fornecedor -->
            <Button
                android:id="@+id/btnNovoFornecedor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_botao_primario"
                android:minHeight="52dp"
                android:text="Cadastrar Fornecedor"
                android:textAllCaps="false"
                android:textColor="@color/cor_texto_claro"
                android:textStyle="bold" />

            <!-- Botão: entrada de estoque -->
            <Button
                android:id="@+id/btnEntradaEstoque"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_botao_primario"
                android:minHeight="52dp"
                android:text="Entrada de Estoque"
                android:textAllCaps="false"
                android:textColor="@color/cor_texto_claro"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Lista de fornecedores -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFornecedores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="8dp"
        android:paddingBottom="12dp" />
</LinearLayout>