<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalhes do Fornecedor"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtDetalheNomeFornecedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome:" />

        <TextView
            android:id="@+id/txtDetalheTelefoneFornecedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Telefone:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtDetalheEmailFornecedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email:"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnEditarDetalheFornecedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar Fornecedor"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnExcluirDetalheFornecedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Excluir Fornecedor"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>