<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtVendaId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Venda #0"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtVendaUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Operador:"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtVendaPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Perfil:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaDataHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data/Hora:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaSubtotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subtotal:"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/txtVendaDesconto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desconto:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaAcrescimo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Acréscimo:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaTotalFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total final:"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaDinheiro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dinheiro:"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/txtVendaPix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pix:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaDebito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Débito:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaCredito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crédito:"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/txtVendaDescontoAutorizado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desconto autorizado por gerente:"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Itens da venda"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/txtItensVenda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Itens"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>