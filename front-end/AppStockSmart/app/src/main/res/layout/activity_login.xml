<?xml version="1.0" encoding="utf-8"?>

<!--
    Tela de login.

    Ajustes aplicados:
    - mantida a estrutura original
    - card centralizado
    - cores atualizadas para a nova paleta
    - campos no padrão bg_input
    - botão principal padronizado
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tela"
    android:padding="24dp">

    <!-- Card principal do login -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/cor_borda"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Conteúdo do card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nome do app -->
            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stooq+"
                android:textColor="@color/cor_texto_principal"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Faça login para acessar o sistema"
                android:textColor="@color/cor_texto_secundario"
                android:textSize="14sp" />

            <!-- Label do login -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Login"
                android:textColor="@color/cor_texto_principal"
                android:textStyle="bold" />

            <!-- Campo de login -->
            <EditText
                android:id="@+id/edtLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Digite seu login"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/cor_texto_principal"
                android:textColorHint="@color/cor_texto_secundario" />

            <!-- Label da senha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Senha"
                android:textColor="@color/cor_texto_principal"
                android:textStyle="bold" />

            <!-- Campo de senha -->
            <EditText
                android:id="@+id/edtSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/cor_texto_principal"
                android:textColorHint="@color/cor_texto_secundario" />

            <!-- Botão principal -->
            <Button
                android:id="@+id/btnEntrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_botao_primario"
                android:minHeight="52dp"
                android:text="Entrar"
                android:textAllCaps="false"
                android:textColor="@color/cor_superficie"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>